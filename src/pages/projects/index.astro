---
import ProjectCard from '@components/projects/ProjectCard.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999),
);

const categories = ['Current projects', 'Past projects'].filter((cat) =>
  projects.some((p) => p.data.category === cat),
);
const hasCategories = categories.length > 0;
---

<Page title="Projects" description={`Projects by ${site.author.name}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">projects</h1>
      <p class="post-description">{site.pages.projects.description}</p>
      <p class="project-note">Only NSF REU at UCSC and CNC Foam Cutter are current projects; the rest are past work.</p>
    </header>

    <article>
      <div class="projects">
        {
          projects.length === 0 ? (
            <p style="color: var(--global-text-color-light);">No projects yet.</p>
          ) : hasCategories ? (
            <>
              {categories.map((cat) => {
                const catProjects = projects.filter((p) => p.data.category === cat);
                return (
                  <>
                    <h2 class="category">{cat}</h2>
                    <div class="projects-grid">
                      {catProjects.map((project) => (
                        <ProjectCard project={project} />
                      ))}
                    </div>
                  </>
                );
              })}
            </>
          ) : (
            <div class="projects-grid">
              {projects.map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          )
        }
      </div>
    </article>
  </div>
</Page>

<script>
  function initCards() {
    // Make cards clickable while allowing inner links to work independently
    document.querySelectorAll<HTMLElement>('.card[data-href]').forEach((card) => {
      card.style.cursor = 'pointer';

      card.addEventListener('click', (e) => {
        // If user clicked an <a> inside, let the browser handle it
        if ((e.target as HTMLElement).closest('a')) return;
        const href = card.dataset.href;
        if (!href) return;
        if (card.dataset.external === 'true') {
          window.open(href, '_blank', 'noopener,noreferrer');
        } else {
          window.location.href = href;
        }
      });

      // Keyboard accessibility
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          card.click();
        }
      });
    });
  }

  // Fetch GitHub star counts from the API
  async function loadGithubStars() {
    const spans = document.querySelectorAll<HTMLElement>('[data-github-stars]');
    await Promise.all(
      [...spans].map(async (span) => {
        const repo = span.dataset.githubStars;
        if (!repo) return;
        try {
          const res = await fetch(`https://api.github.com/repos/${repo}`, {
            headers: { Accept: 'application/vnd.github.v3+json' },
          });
          if (!res.ok) return;
          const data = (await res.json()) as { stargazers_count?: number };
          if (typeof data.stargazers_count === 'number') {
            span.textContent = data.stargazers_count.toLocaleString();
          }
        } catch {
          // Silently ignore — stars are decorative
        }
      }),
    );
  }

  document.addEventListener('astro:page-load', () => {
    initCards();
    loadGithubStars();
  });
</script>

<style>
  /* ── Page structure ─────────────────────────────────────────────────────── */
  .post {
    padding-top: 0;
  }

  .post-description {
    color: var(--global-text-color-light);
    font-size: 1rem;
    margin: 0;
  }

  .project-note {
    margin-top: 0.75rem;
    color: var(--global-text-color-light);
    font-size: 0.95rem;
  }

  /* ── Projects container ─────────────────────────────────────────────────── */
  .projects a {
    text-decoration: none;
  }

  /* Category headings — right-aligned with divider (matches al-folio) */
  h2.category {
    color: var(--global-divider-color);
    border-bottom: 1px solid var(--global-divider-color);
    padding-top: 0.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    text-align: right;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    text-transform: lowercase;
  }

  /* Remove underline from category anchor */
  .projects a:has(h2.category) {
    text-decoration: none;
  }

  /* ── Responsive grid ─────────────────────────────────────────────────────── */
  .projects-grid {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -0.5rem;
  }

</style>
