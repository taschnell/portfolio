---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import yaml from 'js-yaml';

import reposRaw from '../data/repositories.yml?raw';

const reposData = yaml.load(reposRaw) as {
  github_users?: string[];
  github_repos?: string[];
  repo_description_lines_max?: number;
};

const users: string[] = reposData.github_users ?? [];
const repos: string[] = reposData.github_repos ?? [];
const descriptionLines = reposData.repo_description_lines_max ?? 2;
const maxDescriptionLength = descriptionLines * 80;
const githubToken = import.meta.env.GITHUB_TOKEN as string | undefined;
const githubHeaders = {
  Accept: 'application/vnd.github.v3+json',
  ...(githubToken ? { Authorization: `token ${githubToken}` } : {}),
};

async function fetchJson(url: string) {
  try {
    const response = await fetch(url, { headers: githubHeaders });
    if (!response.ok) return null;
    return await response.json();
  } catch {
    return null;
  }
}

function truncate(text: string | null | undefined) {
  if (!text) return '';
  return text.length > maxDescriptionLength
    ? `${text.slice(0, maxDescriptionLength).trim()}...`
    : text;
}

type GitHubUser = {
  login: string;
  name: string | null;
  html_url: string;
  avatar_url: string;
  bio: string | null;
  location: string | null;
  public_repos: number;
  followers: number;
  following: number;
};

type GitHubRepo = {
  full_name: string;
  html_url: string;
  description: string | null;
  stargazers_count: number;
  forks_count: number;
  language: string | null;
  updated_at: string;
};

const fetchedUsers = await Promise.all(
  users.map(async (username) => {
    const data = await fetchJson(`https://api.github.com/users/${username}`);
    if (!data) return null;
    return {
      login: data.login,
      name: data.name,
      html_url: data.html_url,
      avatar_url: data.avatar_url,
      bio: data.bio,
      location: data.location,
      public_repos: data.public_repos,
      followers: data.followers,
      following: data.following,
    } as GitHubUser;
  }),
);

const githubUsers = fetchedUsers.filter(Boolean) as GitHubUser[];

const fallbackUsers = users.map((username) => ({
  login: username,
  name: null,
  html_url: `https://github.com/${username}`,
  avatar_url: `https://github.com/${username}.png`,
  bio: null,
  location: null,
  public_repos: 0,
  followers: 0,
  following: 0,
} as GitHubUser));

const fetchedRepos = await Promise.all(
  repos.map(async (repo) => {
    const [owner, name] = repo.split('/');
    if (!owner || !name) return null;
    const data = await fetchJson(`https://api.github.com/repos/${owner}/${name}`);
    if (!data) return null;
    return {
      full_name: data.full_name,
      html_url: data.html_url,
      description: data.description,
      stargazers_count: data.stargazers_count,
      forks_count: data.forks_count,
      language: data.language,
      updated_at: data.updated_at,
    } as GitHubRepo;
  }),
);

const githubRepos = fetchedRepos.filter(Boolean) as GitHubRepo[];
const fallbackRepos = repos.map((repo) => ({
  full_name: repo,
  html_url: `https://github.com/${repo}`,
  description: null,
  stargazers_count: 0,
  forks_count: 0,
  language: null,
  updated_at: '',
} as GitHubRepo));
---

<Page title="Repositories" description={`GitHub repositories`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">repositories</h1>
      <p class="post-description">
        Edit <code>src/data/repositories.yml</code> to configure GitHub users and repositories.
      </p>
    </header>
    <article>
      {
        site.repositories.githubUsers && users.length > 0 && (
          <>
            <h2 class="section-heading">GitHub users</h2>
            {githubUsers.length > 0 ? (
              <div class="repo-grid">
                {githubUsers.map((user) => (
                  <div class="repo-card repo-card--user">
                    <a href={user.html_url} target="_blank" rel="noopener noreferrer" class="repo-card-link">
                      <img src={user.avatar_url} alt={`Avatar of ${user.login}`} loading="lazy" width="120" height="120" />
                      <div class="repo-card-body">
                        <h3 class="repo-card-title">{user.name ?? user.login}</h3>
                        <p class="repo-card-description">{user.bio ?? 'GitHub profile'}</p>
                        <div class="repo-card-meta">
                          <span>{user.public_repos} repos</span>
                          <span>{user.followers} followers</span>
                          <span>{user.following} following</span>
                        </div>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <>
                <div class="repo-grid">
                  {fallbackUsers.map((user) => (
                    <div class="repo-card repo-card--user">
                      <a href={user.html_url} target="_blank" rel="noopener noreferrer" class="repo-card-link">
                        <img src={user.avatar_url} alt={`Avatar of ${user.login}`} loading="lazy" width="120" height="120" />
                        <div class="repo-card-body">
                          <h3 class="repo-card-title">{user.login}</h3>
                          <p class="repo-card-description">GitHub profile</p>
                          <div class="repo-card-meta">
                            <span>View profile</span>
                          </div>
                        </div>
                      </a>
                    </div>
                  ))}
                </div>
                <p class="repo-warning">
                  GitHub API data was unavailable at build time. Showing profile links instead.
                  Add a <code>GITHUB_TOKEN</code> environment variable to enable full metadata.
                </p>
              </>
            )}
          </>
        )}

      {
        site.repositories.githubRepos && repos.length > 0 && (
          <>
            <div class="divider" />
            <h2 class="section-heading">GitHub repositories</h2>
            {githubRepos.length > 0 ? (
              <div class="repo-grid">
                {githubRepos.map((repo) => (
                  <div class="repo-card">
                    <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="repo-card-link">
                      <div class="repo-card-body">
                        <h3 class="repo-card-title">{repo.full_name}</h3>
                        <p class="repo-card-description">{truncate(repo.description)}</p>
                        <div class="repo-card-meta">
                          {repo.language && <span>{repo.language}</span>}
                          <span>★ {repo.stargazers_count}</span>
                          <span>🍴 {repo.forks_count}</span>
                        </div>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <>
                <div class="repo-grid">
                  {fallbackRepos.map((repo) => (
                    <div class="repo-card">
                      <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="repo-card-link">
                        <div class="repo-card-body">
                          <h3 class="repo-card-title">{repo.full_name}</h3>
                          <p class="repo-card-description">Repository link</p>
                          <div class="repo-card-meta">
                            <span>View on GitHub</span>
                          </div>
                        </div>
                      </a>
                    </div>
                  ))}
                </div>
                <p class="repo-warning">
                  GitHub API data was unavailable at build time. Showing repository links instead.
                  Add a <code>GITHUB_TOKEN</code> environment variable to enable full metadata.
                </p>
              </>
            )}
          </>
        )}
    </article>
  </div>
</Page>

<style>
  .post {
    padding-top: 0;
  }
  .post-description {
    color: var(--global-text-color-light);
    font-size: 0.95rem;
  }
  .post-description code {
    font-family: var(--font-mono, monospace);
    font-size: 0.875em;
    background: var(--global-card-bg-color);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
  .section-heading {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  .divider {
    border-top: 1px solid var(--global-divider-color);
    margin: 2rem 0;
  }
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .repo-card {
    border: 1px solid var(--global-divider-color);
    border-radius: 12px;
    background: var(--global-card-bg-color);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .repo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(0,0,0,0.05);
  }
  .repo-card--user {
    display: flex;
    flex-direction: column;
  }
  .repo-card img {
    width: 100%;
    border-radius: 8px 8px 0 0;
    object-fit: cover;
  }
  .repo-card-body {
    padding: 1rem;
  }
  .repo-card-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--global-text-color);
  }
  .repo-card-description {
    margin: 0.5rem 0 1rem;
    color: var(--global-text-color-light);
    line-height: 1.5;
    min-height: 3em;
  }
  .repo-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--global-text-color-light);
  }
  .repo-card-meta span {
    background: var(--global-card-bg-color);
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
  }
  .repo-warning {
    color: var(--global-text-color-light);
    background: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .repo-warning code {
    font-family: var(--font-mono, monospace);
    background: var(--global-card-bg-color);
    padding: 0.1em 0.25em;
    border-radius: 4px;
  }
</style>
