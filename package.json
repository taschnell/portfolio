{
  "name": "as-folio",
  "description": "A clean, responsive Astro theme for academics and researchers",
  "version": "1.2.0",
  "author": "Dadang NH <hello@dadangnh.com>",
  "homepage": "https://github.com/dadangnh/as-folio",
  "repository": {
    "type": "git",
    "url": "https://github.com/dadangnh/as-folio"
  },
  "bugs": {
    "url": "https://github.com/dadangnh/as-folio/issues"
  },
  "keywords": [
    "astro",
    "astro-theme",
    "astro-component",
    "academic",
    "portfolio",
    "template",
    "as-folio",
    "bibtex",
    "publications"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "src/",
    "public/",
    "astro.config.mjs",
    "tsconfig.json",
    ".prettierrc.yaml",
    "netlify.toml",
    "vercel.json",
    "QUICKSTART.md",
    "CUSTOMIZE.md",
    "MIGRATE.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "astro": ">=6.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node --strip-types scripts/update-citations.ts",
    "build": "astro build --timings && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "astro check && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=junit",
    "test:all": "yarn test:types && yarn lint:ci && yarn test && yarn test:e2e",
    "validate": "yarn test:all",
    "prepare": "husky",
    "citations:update": "node --strip-types scripts/update-citations.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/react": "^5.0.1",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@iconify-json/academicons": "^1.2.1",
    "@iconify-json/fa-brands": "^1.2.2",
    "@iconify-json/fa-regular": "^1.2.1",
    "@iconify-json/fa-solid": "^1.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "6.0.8",
    "astro-icon": "^1.1.4",
    "js-yaml": "^4.1.0",
    "medium-zoom": "^1.1.0",
    "ninja-keys": "^1.2.1",
    "pseudocode": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^4.0.0",
    "astro-eslint-parser": "^1.1.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.0.0"
  }
}
